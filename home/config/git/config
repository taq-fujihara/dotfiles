[core]
    editor = nvim
    quotepath = false
    ignorecase = false
    pager = delta

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    light = false

    syntax-theme = Nord

    plus-style = syntax "#3A4F5A"
    plus-emph-style = syntax bold "#425965"
    line-numbers-plus-style = "#94AEC0"
    minus-style = syntax "#443B47"
    minus-emph-style = syntax bold "#674758"
    line-numbers-minus-style = "#A8848C"

    features = "view-side-by-side"

[delta "view-side-by-side"]
    side-by-side = true

[delta "view-unified"]
    side-by-side = false

[commit]
    verbose = true

[rerere]
    enabled = true
    autoupdate = true

[merge]
    conflictstyle = diff3

[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true

[rebase]
    updateRefs = true
    autoSquash = true
    autoStash = true

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[pull]
    ff = only

[hook "force-push-confirmation"]
    event = pre-push
    command = ~/.config/git/hooks/force-push-confirmation.fish

[alias]
    alias = config --get-regexp alias.*
    me = config --get-regexp user
    diff-unified = -c delta.side-by-side=false diff
    diff-auto = "!f() { \
        cols=$(tput cols 2>/dev/null || echo 80); \
        if [ $cols -lt 160 ]; then \
            git -c delta.side-by-side=false diff \"$@\"; \
        else \
            git diff \"$@\"; \
        fi; \
    }; f"
    summary = status --short --untracked-files
    graph = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
    graphs = graph --all
    show-unified = -c delta.side-by-side=false show
    show-auto = "!f() { \
        cols=$(tput cols 2>/dev/null || echo 80); \
        if [ $cols -lt 160 ]; then \
            git -c delta.side-by-side=false show \"$@\"; \
        else \
            git show \"$@\"; \
        fi; \
    }; f"
    ahead = graph @{u}..HEAD
    behind = graph ..FETCH_HEAD
    staged = diff --staged
    staged-unified = -c delta.side-by-side=false diff --staged
    staged-auto = "!f() { \
        cols=$(tput cols 2>/dev/null || echo 80); \
        if [ $cols -lt 160 ]; then \
            git -c delta.side-by-side=false diff --staged \"$@\"; \
        else \
            git staged \"$@\"; \
        fi; \
    }; f"
    stashes = stash list
    stash-all = stash --include-untracked
    save = stash push
    branches = branch -a
    create-and-switch = switch -c
    delete-branch = branch -d
    rename-branch = branch -m
    remotes = remote -v
    amend = commit --amend
    fixup = commit --fixup
    fixup-last = commit --fixup HEAD~1
    edit = commit --amend --only
    unstage = restore --staged
    discard = restore
    please = push --force-with-lease --force-if-includes

    # shortened version of existing commands. should be least.
    # st = status
    # sw = switch
    # gr = graph

    # scripts
    cz = "!bun x git-cz -e"
    ignore-dir = "!echo '\n# created by \"ignore-dir\" alias\n*' >> ${GIT_PREFIX:-.}/.gitignore"

[help]
    autocorrect = prompt

[credential "https://source.developers.google.com"]
    helper = gcloud.sh

[include]
    path = ~/.config/git/.gitconfig.local
