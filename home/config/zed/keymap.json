// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "secondary-h": "workspace::ActivatePaneLeft",
      "secondary-l": "workspace::ActivatePaneRight",
      "secondary-j": "workspace::ActivatePaneDown",
      "secondary-k": "workspace::ActivatePaneUp",
      "f5": "debugger::Start",
      "f10": "debugger::StepOver",
      "f11": "debugger::StepInto",
      "shift-f11": "debugger::StepOut",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "secondary-h": "workspace::ActivatePaneLeft",
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "c": "project_panel::Duplicate",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j j": "vim::NormalBefore",
      "shift-space": "editor::ShowCompletions",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      ";": "command_palette::Toggle",
      "L": "pane::ActivateNextItem",
      "H": "pane::ActivatePreviousItem",
      "|": "pane::SplitRight",
      "-": "pane::SplitDown",
      "s": "vim::HelixJumpToWord",
      "space w": "workspace::Save",
      "space c": "pane::CloseActiveItem",
      "space q": "pane::CloseActiveItem",
      "space o": "project_panel::ToggleFocus",
      "space e": "workspace::ToggleRightDock",
      "space n": "workspace::NewFile",
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f w": "pane::DeploySearch",
      "space /": "editor::ToggleComments",
      "space l r": "editor::Rename",
      "space l R": "editor::FindAllReferences",
      "space l s": "outline::Toggle",
      "space g g": ["task::Spawn", { "task_name": "start lazygit" }],
      "up": "vim::ResizePaneUp",
      "down": "vim::ResizePaneDown",
      "left": "vim::ResizePaneLeft",
      "right": "vim::ResizePaneRight",
      "shift-up": "vim::ResizePaneDown",
      "shift-down": "vim::ResizePaneUp",
      "shift-left": "vim::ResizePaneRight",
      "shift-right": "vim::ResizePaneLeft",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "space g g": "git_panel::Toggle",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      ";": "command_palette::Toggle",
      "space /": "editor::ToggleComments",
    },
  },
]
